+    /* Interactive VR avatar */
+    .vr-avatar-wrap { width:130px; height:130px; flex-shrink:0; display:flex; align-items:center; justify-content:center; perspective:600px; }
+    .vr-avatar { width:100%; height:100%; display:block; cursor:pointer; }
+    .vr-avatar .vr-head-group { transform-origin:70px 78px; animation:vr-look-around 7s ease-in-out infinite; transition:transform 0.35s ease-out; }
+    .vr-avatar:hover .vr-head-group { animation-play-state:paused; }
+    .vr-avatar .vr-lens-glow { animation:vr-lens-pulse 2.6s ease-in-out infinite; transform-origin:center; }
+    @keyframes vr-look-around {
+      0%   { transform:rotate(-12deg) translateY(0); }
+      18%  { transform:rotate(-12deg) translateY(-4px); }
+      35%  { transform:rotate(0deg) translateY(2px); }
+      52%  { transform:rotate(0deg) translateY(-3px); }
+      70%  { transform:rotate(12deg) translateY(-4px); }
+      88%  { transform:rotate(12deg) translateY(2px); }
+      100% { transform:rotate(-12deg) translateY(0); }
+    }
+    @keyframes vr-lens-pulse {
+      0%, 100% { opacity:0.85; }
+      50%      { opacity:1; }
+    }
+    @media (prefers-reduced-motion: reduce) {
+      .vr-avatar .vr-head-group, .vr-avatar .vr-lens-glow { animation:none; }
+    }
+    html[data-a11y-motion="on"] .vr-avatar .vr-head-group,
+    html[data-a11y-motion="on"] .vr-avatar .vr-lens-glow { animation:none !important; }
+    @media (max-width:720px) {
